<?xml version="1.0" encoding="utf-8"?>

<Window x:Class="XrayUI.Views.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="代理日志">

    <Grid x:Name="WindowRoot" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Log text area -->
        <ScrollViewer x:Name="LogScrollViewer"
                      Grid.Row="0"
                      Padding="12,12,12,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">
            <TextBlock x:Name="LogTextBlock"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="12"
                       IsTextSelectionEnabled="True"
                       TextWrapping="NoWrap"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
        </ScrollViewer>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Padding="12,8"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <!-- Status -->
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot"
                             Width="8" Height="8"
                             VerticalAlignment="Center"
                             Fill="{ThemeResource SystemFillColorCautionBrush}" />
                    <TextBlock x:Name="StatusText"
                               Text="未运行"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="LineCountText"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button x:Name="LogPrivacyButton"
                            Padding="8,5">
                        <FontIcon Glyph="&#xE72E;"
                                  FontSize="13" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutSubItem x:Name="MaskAddressSubMenu" Text="IP地址遮罩">
                                    <RadioMenuFlyoutItem x:Name="MaskOffMenuItem"
                                                         Text="关闭"
                                                         GroupName="LogMaskAddressGroup"
                                                         Tag=""
                                                         Click="MaskAddressMenuItem_Click" />
                                    <RadioMenuFlyoutItem x:Name="MaskQuarterMenuItem"
                                                         Text="quarter"
                                                         GroupName="LogMaskAddressGroup"
                                                         Tag="quarter"
                                                         Click="MaskAddressMenuItem_Click" />
                                    <RadioMenuFlyoutItem x:Name="MaskHalfMenuItem"
                                                         Text="half"
                                                         GroupName="LogMaskAddressGroup"
                                                         Tag="half"
                                                         Click="MaskAddressMenuItem_Click" />
                                    <RadioMenuFlyoutItem x:Name="MaskFullMenuItem"
                                                         Text="full"
                                                         GroupName="LogMaskAddressGroup"
                                                         Tag="full"
                                                         Click="MaskAddressMenuItem_Click" />
                                </MenuFlyoutSubItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <ToggleButton x:Name="AutoScrollToggle"
                                  IsChecked="True"
                                  FontSize="12"
                                  Padding="10,5" />
                    <Button x:Name="CopyButton"
                            FontSize="12"
                            Padding="10,5"
                            Click="CopyButton_Click" />
                    <Button x:Name="ClearButton"
                            FontSize="12"
                            Padding="10,5"
                            Click="ClearButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
